<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <virtualType name="Paydibs\PaymentGateway\Logger\Handler" type="Magento\Framework\Logger\Handler\Base">
        <arguments>
            <argument name="fileName" xsi:type="string">/var/log/paydibs.log</argument>
        </arguments>
    </virtualType>
    <virtualType name="Paydibs\PaymentGateway\Logger\Monolog" type="Magento\Framework\Logger\Monolog">
        <arguments>
            <argument name="name" xsi:type="string">paydibs</argument>
            <argument name="handlers" xsi:type="array">
                <item name="0" xsi:type="object">Paydibs\PaymentGateway\Logger\Handler</item>
            </argument>
        </arguments>
    </virtualType>
    <type name="Paydibs\PaymentGateway\Model\PaymentMethod">
        <arguments>
            <argument name="paydibsPsrLogger" xsi:type="object">Paydibs\PaymentGateway\Logger\Monolog</argument>
        </arguments>
    </type>
</config>
